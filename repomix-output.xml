    <path d="M -15 35 L 60 -15 L 135 35 L 125 45 L 60 -1 L -5 45 Z" fill="#202e2b" />
    <path d="M 60 -15 L 135 35 L 125 45 L 60 -1 Z" fill="#2d3b39" />
    {/* Glowing Window */}
    <circle cx="60" cy="45" r="16" fill="#f59e0b" filter="url(#window-glow)" />
    <circle cx="60" cy="45" r="16" fill="none" stroke="#261007" strokeWidth="2" />
    <path d="M 60 29 L 60 61 M 44 45 L 76 45" stroke="#261007" strokeWidth="3" />
    {/* Creepy Doorway */}
    <path d="M 40 125 L 40 85 Q 60 75 80 85 L 80 125 Z" fill="#050302" />
  </g>
);

const Fireflies = () => {
  const positions = [
    {x: 340, y: 190}, {x: 500, y: 310}, {x: 400, y: 250}, 
    {x: 550, y: 210}, {x: 290, y: 290}, {x: 700, y: 320}, 
    {x: 640, y: 160}, {x: 800, y: 250}, {x: 220, y: 220},
    {x: 850, y: 190}, {x: 180, y: 380}, {x: 1000, y: 300}
  ];
  
  return (
    <g>
      {positions.map((pos, i) => (
        <g key={i}>
          <circle cx={pos.x} cy={pos.y} r="6" fill="#d9f564" filter="url(#firefly-glow)" opacity="0.6">
            <animate attributeName="opacity" values="0; 0.8; 0" dur={`${2.5 + (i % 3)}s`} begin={`${i * 0.4}s`} repeatCount="indefinite" />
          </circle>
          <circle cx={pos.x} cy={pos.y} r="1.5" fill="#eaff8a">
            <animate attributeName="opacity" values="0.1; 1; 0.1" dur={`${2.5 + (i % 3)}s`} begin={`${i * 0.4}s`} repeatCount="indefinite" />
          </circle>
        </g>
      ))}
    </g>
  );
};

const ProceduralFences = () => {
  const spacing = 35;
  const points = [];

  const addLine = (y, startX, endX) => {
    const dir = startX < endX ? 1 : -1;
    const dist = Math.abs(endX - startX);
    const steps = Math.floor(dist / spacing);
    for (let i = 0; i <= steps; i++) {
      points.push({ x: startX + (i * spacing * dir), y });
    }
  };

  const addArc = (cx, cy, r, startAngle, endAngle) => {
    const arcLen = Math.abs(endAngle - startAngle) * r;
    const steps = Math.floor(arcLen / spacing);
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const a = startAngle + t * (endAngle - startAngle);
      points.push({ x: cx + Math.cos(a) * r, y: cy + Math.sin(a) * r });
    }
  };

  addLine(60, 250, 950);
  addArc(950, 250, 190, -Math.PI/2, Math.PI/2);
  addLine(440, 950, 250);
  addArc(250, 250, 190, Math.PI/2, (3*Math.PI)/2);

  addLine(140, 250, 950);
  addArc(950, 250, 110, -Math.PI/2, Math.PI/2);
  addLine(360, 950, 250);
  addArc(250, 250, 110, Math.PI/2, (3*Math.PI)/2);

  return (
    <g>
      <path d="M 250 60 L 950 60 A 190 190 0 0 1 950 440 L 250 440 A 190 190 0 0 1 250 60 Z" fill="none" stroke="#1c110b" strokeWidth="2.5" opacity="0.8" filter="url(#drop-shadow)"/>
      <path d="M 250 140 L 950 140 A 110 110 0 0 1 950 360 L 250 360 A 110 110 0 0 1 250 140 Z" fill="none" stroke="#1c110b" strokeWidth="2.5" opacity="0.8" filter="url(#drop-shadow)"/>
      {points.map((p, i) => (
        <g key={i} transform={`translate(${p.x}, ${p.y})`} filter="url(#drop-shadow)">
          <circle r="4.5" fill="#362217" />
          <circle r="2.5" fill="#5c3b28" />
        </g>
      ))}
    </g>
  );
};

