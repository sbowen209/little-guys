import { assetUrl } from '../utils/assets';

// -----------------------------------------------------------------------------
// PROCEDURAL ENVIRONMENT COMPONENTS (VISUALLY ENHANCED)
// -----------------------------------------------------------------------------

const Tree = ({ cx, cy, r }) => (
  <g filter="url(#drop-shadow)">
