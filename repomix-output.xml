    <circle cx={cx - r * 0.15} cy={cy - r * 0.15} r={r * 0.7} fill="url(#tree-mid)" />
    <circle cx={cx + r * 0.2} cy={cy + r * 0.15} r={r * 0.4} fill="url(#tree-highlight)" opacity="0.8" />
  </g>
);

const LilyPad = ({ cx, cy, scale = 1, rot = 0 }) => (
  <g transform={`translate(${cx}, ${cy}) scale(${scale}) rotate(${rot})`} filter="url(#drop-shadow)">
    <path d="M 12 0 A 12 12 0 1 1 -12 0 A 12 12 0 0 1 -3 -10 L 0 0 L 3 -10 A 12 12 0 0 1 12 0 Z" fill="url(#lilypad-grad)" />
    <path d="M 12 0 A 12 12 0 1 1 -12 0 A 12 12 0 0 1 -3 -10 L 0 0 L 3 -10 A 12 12 0 0 1 12 0 Z" fill="none" stroke="#65a345" strokeWidth="0.5" opacity="0.6"/>
  </g>
);

const SwampPond = () => (
  <g filter="url(#drop-shadow)">
    <path d="M 300 220 C 340 130, 480 130, 530 190 C 620 260, 560 360, 480 340 C 360 340, 230 330, 300 220 Z" fill="url(#swamp-water-grad)" />
    <path d="M 300 220 C 340 130, 480 130, 530 190 C 620 260, 560 360, 480 340 C 360 340, 230 330, 300 220 Z" fill="none" stroke="#162e1c" strokeWidth="4" opacity="0.8" />
    <path d="M 315 225 C 345 145, 475 145, 515 200 C 590 260, 545 345, 475 325 C 375 325, 260 315, 315 225 Z" fill="none" stroke="#376643" strokeWidth="1.5" opacity="0.3" />
    
    <LilyPad cx="340" cy="180" scale={1.3} rot={45} />
