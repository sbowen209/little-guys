<file path="src/hooks/useRaceEngine.js">
import { useState, useCallback } from 'react';

// Hardcoded for "The Oval Circuit" based on our SVG Map
// Total Length: 150 units
const TRACK_DATA = {
  length: 150,
  jumps: {
    25: 10,   // Position: 25, Difficulty: 10
    85: 10,   // Position: 85, Difficulty: 10
    100: 15,  // Position: 100, Difficulty: 15
    115: 10,  // Position: 115, Difficulty: 10
  },
  turns: [
    { start: 50, end: 75 },
    { start: 125, end: 150 },
  ],
};

const rollDice = (max) => Math.floor(Math.random() * max) + 1;

export function useRaceEngine(initialRacers) {
  const [activeRacerIndex, setActiveRacerIndex] = useState(0);
  const [isFinished, setIsFinished] = useState(false);
  const [winner, setWinner] = useState(null);
  const [logs, setLogs] = useState(["Engine Initialized. Racers ready."]);

  // Extend initial racers with race state
  const [racers, setRacers] = useState(
    initialRacers.map((r, i) => ({
      ...r,
      engineId: `racer_${i}`,
      position: 0,
      isPenalized: false,
    }))
  );

  const addLog = (msg) => {
    setLogs((prev) => [...prev, msg]);
  };

  const takeTurn = useCallback(() => {
    if (isFinished) return;

    setRacers((prevRacers) => {
      const currentRacers = [...prevRacers];
      const racer = { ...currentRacers[activeRacerIndex] };
      const stats = racer.racingStats;
      let pos = racer.position;

      // 1. Determine Starting Terrain & Base Stat
      const isInTurn = TRACK_DATA.turns.some((t) => pos >= t.start && pos < t.end);
      const activeStat = isInTurn ? stats.turning : stats.speed;
      const statName = isInTurn ? 'Turn' : 'Speed';

      // 2. Roll for movement (apply penalty if active)
      let movement = rollDice(activeStat);
      
      if (racer.isPenalized) {
        movement = Math.floor(movement / 2);
        racer.isPenalized = false; // Reset penalty after applying
        addLog(`${racer.name} is recovering. Rolled ${movement} (${statName}, halved).`);
      } else {
        addLog(`${racer.name} rolls ${movement} for ${statName}.`);
      }

      // 3. Process Movement Unit-by-Unit
      let movementRemaining = movement;
      let stoppedEarly = false;

      while (movementRemaining > 0 && pos < TRACK_DATA.length) {
        const nextPos = pos + 1;

        // Check if crossing INTO a turn from a straight
        const hitsTurnBoundary = TRACK_DATA.turns.some((t) => t.start === nextPos);
        if (hitsTurnBoundary && !isInTurn) {
          pos = nextPos;
          addLog(`${racer.name} hits a turn and loses remaining momentum.`);
          stoppedEarly = true;
          break;
        }

        // Check if hitting a Jump
        if (TRACK_DATA.jumps[nextPos]) {
          const jumpDiff = TRACK_DATA.jumps[nextPos];
          pos = nextPos;
          const jumpRoll = rollDice(stats.jump);

          if (jumpRoll >= jumpDiff) {
            addLog(`${racer.name} cleared the jump! (Rolled ${jumpRoll} vs ${jumpDiff})`);
            movementRemaining--; // Cost 1 unit of movement to pass through
            continue; 
          } else {
            addLog(`CRASH! ${racer.name} failed the jump. (Rolled ${jumpRoll} vs ${jumpDiff}). Penalty applied.`);
            racer.isPenalized = true;
            stoppedEarly = true;
            break; // Stop immediately
          }
        }

        // Normal movement
        pos = nextPos;
        movementRemaining--;
      }

      // Update state
      racer.position = pos;
      currentRacers[activeRacerIndex] = racer;

      // Check Win Condition
      if (pos >= TRACK_DATA.length) {
        addLog(`🏁 ${racer.name} crosses the finish line!`);
        setIsFinished(true);
        setWinner(racer);
      }

      return currentRacers;
    });

    if (!isFinished) {
      setActiveRacerIndex((prev) => (prev === 0 ? 1 : 0));
    }
  }, [activeRacerIndex, isFinished]);

  return {
    racers,
    activeRacerIndex,
    logs,
    isFinished,
    winner,
    takeTurn,
    trackData: TRACK_DATA
  };
}
