    <LilyPad cx="305" cy="265" scale={1.2} rot={80} />
    <LilyPad cx="540" cy="230" scale={0.9} rot={160} />
  </g>
);

const SwampBarn = () => (
  <g transform="translate(680, 160)" filter="url(#drop-shadow)">
    {/* Base structure outline/shadow */}
    <rect x="-5" y="-5" width="130" height="135" fill="#140a08" rx="2" />
    {/* Wooden Frame */}
    <rect x="0" y="30" width="120" height="95" fill="url(#barn-wood)" />
