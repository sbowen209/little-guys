// src/views/RacingSetup.jsx
import { useState } from 'react';
import { HEROES } from '../data/heroes';
import { assetUrl } from '../utils/assets';

const TRACKS = [
  { id: 'track_a', name: 'The Oval', desc: 'A standard dirt track with sweeping 25-unit turns and long straights.' },
  { id: 'track_b', name: 'Sprint Circuit', desc: 'Heavy on straightaways, built entirely for max speed.' },
  { id: 'track_c', name: 'Hazard Hollow', desc: 'Technical dirt track littered with consecutive 15-unit jumps.' },
  { id: 'track_d', name: 'Serpent\'s Tail', desc: 'Sharp, erratic turning segments demanding high maneuverability.' },
];

function StatBar({ label, value, colorClass }) {
  return (
    <div className="mb-2.5 w-full">
      <div className="mb-1 flex justify-between font-mono text-[10px] font-bold uppercase tracking-widest text-stone-400">
        <span>{label}</span>
        <span className="text-white">{value}</span>
      </div>
      <div className="h-1.5 w-full overflow-hidden rounded-full bg-stone-900 shadow-inner">
        <div
          className={`h-full rounded-full transition-all duration-700 ease-out ${colorClass}`}
          style={{ width: `${value}%` }}
        />
      </div>
    </div>
  );
}

export default function RacingSetup({ onBack, onBeginRace }) {
  const heroes = Object.values(HEROES);
  
  const [selectedRacers, setSelectedRacers] = useState([]);
  const [selectedTrack, setSelectedTrack] = useState(null);

  const toggleRacer = (heroId) => {
    setSelectedRacers((prev) => {
      if (prev.includes(heroId)) {
        return prev.filter((id) => id !== heroId);
      }
      if (prev.length < 2) {
        return [...prev, heroId];
      }
      return prev; // Block if 2 are already selected
    });
  };

  const isReady = selectedRacers.length === 2 && selectedTrack !== null;

  const handleStart = () => {
    // Map the IDs back to the full Hero objects to pass to the race component
    const racers = selectedRacers.map(id => HEROES[id]);
    onBeginRace(racers, selectedTrack);
  };

  return (
    <div className="mx-auto max-w-7xl p-6 lg:p-10">
      <header className="mb-10 flex flex-col gap-4 border-b border-stone-800 pb-6 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 className="bg-gradient-to-br from-rose-300 via-rose-500 to-rose-700 bg-clip-text font-serif text-4xl font-black tracking-tighter text-transparent drop-shadow-[0_2px_10px_rgba(244,63,94,0.3)] lg:text-5xl">
            RACING SETUP
          </h1>
          <p className="mt-1 font-mono text-xs uppercase tracking-widest text-stone-500">
            Configure Your Heat
          </p>
        </div>
        <button
          type="button"
          onClick={onBack}
          className="rounded-lg border border-stone-700 bg-stone-900/50 px-6 py-2.5 text-xs font-bold uppercase tracking-wider text-stone-400 transition hover:bg-stone-800 hover:text-stone-200"
        >
          Back to Gateway
        </button>
      </header>

      {/* Racer Selection */}
      <section className="mb-12">
        <div className="mb-6 flex items-center justify-between">
          <h2 className="font-mono text-sm font-bold uppercase tracking-[0.2em] text-stone-300">
            1. Select Racers
          </h2>
          <span
            className={`rounded bg-stone-900 px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-widest shadow-inner ${
              selectedRacers.length === 2 ? 'text-emerald-400 border border-emerald-500/30' : 'text-amber-400 border border-amber-500/30'
            }`}
          >
            {selectedRacers.length} / 2 Selected
          </span>
        </div>

        <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
          {heroes.map((hero) => {
            const isSelected = selectedRacers.includes(hero.id);
            const isDisabled = !isSelected && selectedRacers.length >= 2;

            return (
              <button
                key={hero.id}
                type="button"
                onClick={() => toggleRacer(hero.id)}
                disabled={isDisabled}
                className={`group relative flex flex-col items-center overflow-hidden rounded-2xl border-2 p-5 text-left transition-all duration-300 ${
                  isSelected
                    ? 'border-amber-400 bg-stone-800/90 shadow-[0_0_30px_rgba(251,191,36,0.25)]'
                    : isDisabled
                    ? 'border-stone-800 bg-stone-900/40 opacity-40 cursor-not-allowed grayscale'
                    : 'border-stone-700 bg-stone-900/60 hover:-translate-y-1 hover:border-stone-500 hover:bg-stone-800 hover:shadow-xl'
                }`}
              >
                <div className="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-stone-800/80 to-transparent opacity-50" />
                
                <img
                  src={assetUrl(hero.imagePath)}
                  alt={hero.name}
                  draggable={false}
                  className="relative z-10 mb-5 h-28 w-28 object-contain drop-shadow-[0_10px_15px_rgba(0,0,0,0.8)] transition-transform duration-500 group-hover:scale-110"
                />
                
                <h3 className={`relative z-10 mb-5 font-serif text-xl font-black ${isSelected ? 'text-amber-400' : 'text-white'}`}>
                  {hero.name}
                </h3>

                <div className="relative z-10 w-full">
                  <StatBar label="Speed" value={hero.racingStats.speed} colorClass="bg-sky-400 shadow-[0_0_8px_rgba(56,189,248,0.6)]" />
                  <StatBar label="Jump" value={hero.racingStats.jump} colorClass="bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.6)]" />
                  <StatBar label="Turning" value={hero.racingStats.turning} colorClass="bg-rose-400 shadow-[0_0_8px_rgba(251,113,133,0.6)]" />
                </div>

                {isSelected && (
                  <div className="absolute right-3 top-3 flex h-7 w-7 animate-[lootPop_0.3s_ease-out_both] items-center justify-center rounded-full bg-amber-400 text-stone-950 shadow-[0_0_15px_rgba(251,191,36,0.8)]">
                    <span className="text-sm font-black leading-none">✓</span>
                  </div>
                )}
              </button>
            );
          })}
        </div>
      </section>

      {/* Track Selection */}
      <section className="mb-12">
        <h2 className="mb-6 font-mono text-sm font-bold uppercase tracking-[0.2em] text-stone-300">
          2. Select Track Layout
        </h2>
        <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4">
          {TRACKS.map((track) => {
            const isSelected = selectedTrack === track.id;
            return (
              <button
                key={track.id}
                type="button"
                onClick={() => setSelectedTrack(track.id)}
                className={`relative flex flex-col justify-center overflow-hidden rounded-2xl border-2 p-6 text-left transition-all duration-300 ${
                  isSelected
                    ? 'border-rose-500 bg-stone-800 shadow-[0_0_25px_rgba(244,63,94,0.3)] -translate-y-1'
                    : 'border-stone-700 bg-stone-900/60 hover:-translate-y-1 hover:border-stone-500 hover:bg-stone-800'
                }`}
              >
                <h3 className={`mb-2 font-serif text-xl font-black ${isSelected ? 'text-rose-400' : 'text-white'}`}>
                  {track.name}
                </h3>
                <p className="text-xs leading-relaxed text-stone-400">
                  {track.desc}
                </p>
                {isSelected && (
                  <div className="absolute right-3 top-3 flex h-6 w-6 animate-[lootPop_0.3s_ease-out_both] items-center justify-center rounded-full bg-rose-500 text-white shadow-[0_0_15px_rgba(244,63,94,0.8)]">
                    <span className="text-xs font-black leading-none">✓</span>
                  </div>
                )}
              </button>
            );
          })}
        </div>
      </section>

      {/* Initialization Action */}
      <div className="flex justify-center pt-6 pb-20">
        <button
          type="button"
          disabled={!isReady}
          onClick={handleStart}
          className="group relative overflow-hidden rounded-xl border border-rose-500/50 bg-rose-600 px-16 py-6 font-black uppercase tracking-widest text-white shadow-[0_0_25px_rgba(225,29,72,0.4)] transition-all enabled:hover:-translate-y-1 enabled:hover:bg-rose-500 enabled:hover:shadow-[0_0_45px_rgba(225,29,72,0.8)] disabled:cursor-not-allowed disabled:opacity-40 disabled:grayscale"
        >
          <span className="pointer-events-none absolute inset-0 -translate-x-full -skew-x-12 bg-white/20 transition-all duration-700 group-hover:animate-[shine_0.7s_ease-out]" />
          <span className="relative text-lg">Initialize Race</span>
        </button>
      </div>

      <style dangerouslySetInnerHTML={{ __html: `
        @keyframes shine { to { transform: translateX(220%) skewX(-12deg); } }
        @keyframes lootPop { 0% { opacity: 0; transform: scale(0.5) translateY(10px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
        @media (prefers-reduced-motion: reduce) { 
           .group-hover\\:animate-\\[shine_0\\.7s_ease-out\\], .animate-\\[lootPop_0\\.3s_ease-out_both\\] { animation: none !important; } 
        }
      `}} />
    </div>
  );
}
