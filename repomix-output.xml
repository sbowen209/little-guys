import { assetUrl } from '../utils/assets';
import { useRaceEngine } from '../hooks/useRaceEngine';
import RaceBoard from '../components/RaceBoard';

// -----------------------------------------------------------------------------
// MATH & POSITION HELPERS
// -----------------------------------------------------------------------------

// Maps the 0-150 game position to X/Y coordinates on the SVG track
// laneIndex 0 = Inner Lane, laneIndex 1 = Outer Lane
function getRacerCoordinates(pos, laneIndex) {
  const normalizedPos = Math.min(pos, 150);
  const isInner = laneIndex === 0;

  let x, y;

  if (normalizedPos <= 50) {
    // Top Straight (X goes 250 -> 950)
    const progress = normalizedPos / 50;
    x = 250 + progress * 700;
    y = isInner ? 120 : 80;
  } else if (normalizedPos <= 75) {
    // Right Turn (Center 950, 250)
    const progress = (normalizedPos - 50) / 25;
    const angle = -Math.PI / 2 + (progress * Math.PI);
    const r = isInner ? 130 : 170;
    x = 950 + Math.cos(angle) * r;
    y = 250 + Math.sin(angle) * r;
  } else if (normalizedPos <= 125) {
    // Bottom Straight (X goes 950 -> 250)
    const progress = (normalizedPos - 75) / 50;
    x = 950 - progress * 700;
    y = isInner ? 380 : 420;
  } else {
    // Left Turn (Center 250, 250)
    const progress = (normalizedPos - 125) / 25;
    const angle = Math.PI / 2 + (progress * Math.PI);
    const r = isInner ? 130 : 170;
    x = 250 + Math.cos(angle) * r;
    y = 250 + Math.sin(angle) * r;
  }

  // Offset by -25 to center the 50x50 foreignObject exactly on the line
  return { x: x - 25, y: y - 25 };
}

// -----------------------------------------------------------------------------
// UI COMPONENTS
// -----------------------------------------------------------------------------

function MiniRacerCard({ hero, laneColor, isActive, position }) {
  return (
    <div className={`flex flex-1 items-center gap-4 rounded-2xl border bg-stone-900/80 p-4 backdrop-blur-md transition-all duration-300 ${isActive ? `border-${laneColor.split('-')[1]}-500 shadow-[0_0_20px_rgba(0,0,0,0.5)] scale-105` : 'border-stone-800 opacity-60'}`}>
      <div className={`relative flex h-16 w-16 shrink-0 items-center justify-center rounded-full border-4 ${laneColor} bg-stone-950 shadow-inner`}>
        <img src={assetUrl(hero.imagePath)} alt={hero.name} draggable={false} className="h-14 w-14 object-contain drop-shadow-md" />
        {hero.isPenalized && (
          <div className="absolute -right-2 -top-2 flex h-6 w-6 items-center justify-center rounded-full bg-red-600 text-[10px] font-black text-white shadow-md">
            !
          </div>
        )}
      </div>
      <div className="flex-1">
        <div className="flex items-start justify-between">
          <h3 className="mb-2 font-serif text-xl font-black text-white">{hero.name}</h3>
          <span className="font-mono text-xs font-bold text-stone-400">POS: {position}</span>
        </div>
        <div className="flex gap-4">
           <div className="flex flex-col"><span className="font-mono text-[9px] uppercase tracking-widest text-stone-500">Speed</span><span className="font-mono font-bold text-sky-400">{hero.racingStats.speed}</span></div>
           <div className="flex flex-col"><span className="font-mono text-[9px] uppercase tracking-widest text-stone-500">Jump</span><span className="font-mono font-bold text-emerald-400">{hero.racingStats.jump}</span></div>
           <div className="flex flex-col"><span className="font-mono text-[9px] uppercase tracking-widest text-stone-500">Turn</span><span className="font-mono font-bold text-rose-400">{hero.racingStats.turning}</span></div>
        </div>
      </div>
    </div>
  );
}

// -----------------------------------------------------------------------------
// MAIN RACE VIEW
// -----------------------------------------------------------------------------

export default function ActiveRace({ racers: initialRacers, onAbandon }) {
  const { 
    racers, 
    activeRacerIndex, 
    logs, 
    isFinished, 
    winner, 
    takeTurn
  } = useRaceEngine(initialRacers);

  const [racer1, racer2] = racers;
  const activeRacer = racers[activeRacerIndex];
  const latestLog = logs[logs.length - 1];

  const r1Coords = getRacerCoordinates(racer1.position, 0); // Lane 0
  const r2Coords = getRacerCoordinates(racer2.position, 1); // Lane 1
  
  return (
    <div className="flex min-h-screen flex-col bg-stone-950 text-stone-200">
      <header className="flex items-center justify-between border-b border-stone-800 bg-stone-950/80 px-6 py-4 backdrop-blur-md">
        <div>
          <h1 className="font-serif text-2xl font-black text-rose-500">THE OVAL CIRCUIT</h1>
          <p className="font-mono text-[10px] uppercase tracking-[0.2em] text-stone-500">Engine Engaged</p>
        </div>
        <button type="button" onClick={onAbandon} className="rounded-lg border border-rose-900/50 px-4 py-2 text-xs font-bold uppercase tracking-wider text-rose-400 transition hover:bg-rose-500/15 hover:text-rose-300">
          Abandon Race
        </button>
      </header>

      <div className="relative flex flex-1 items-center justify-center overflow-hidden bg-stone-950 shadow-[inset_0_0_150px_rgba(0,0,0,1)]">
        <RaceBoard 
          racer1={racer1}
          racer2={racer2}
          r1Coords={r1Coords}
          r2Coords={r2Coords}
          activeRacerIndex={activeRacerIndex}
          isFinished={isFinished}
        />
      </div>

      <div className="z-20 border-t border-stone-800 bg-stone-950 px-6 py-6 shadow-[0_-15px_30px_rgba(0,0,0,0.6)]">
         <div className="mx-auto flex max-w-6xl items-stretch gap-8">
            <MiniRacerCard 
              hero={racer1} 
              laneColor="border-amber-400" 
              isActive={activeRacerIndex === 0 && !isFinished}
              position={racer1.position} 
            />
            
            <div className="flex w-72 shrink-0 flex-col items-center justify-center rounded-2xl border-2 border-stone-800 bg-stone-900/50 p-4">
              <span className="mb-2 font-mono text-[10px] uppercase tracking-[0.2em] text-stone-500">
                {isFinished ? 'RACE OVER' : `${activeRacer.name}'s Turn`}
              </span>
              
              <div className="mb-4 flex h-10 w-full items-center justify-center text-center">
                <p className="text-xs font-medium italic text-stone-300 line-clamp-2">
                  {isFinished ? `🏆 ${winner?.name} has won the race!` : latestLog}
                </p>
              </div>

              <button 
                onClick={takeTurn}
                disabled={isFinished}
                className="w-full rounded-lg bg-rose-600 py-3 font-black uppercase tracking-widest text-white shadow-lg transition hover:-translate-y-1 hover:bg-rose-500 hover:shadow-[0_0_20px_rgba(225,29,72,0.4)] disabled:opacity-30 disabled:hover:translate-y-0 disabled:hover:shadow-none"
              >
                {isFinished ? 'Finished' : 'Execute Turn'}
              </button>
            </div>

            <MiniRacerCard 
              hero={racer2} 
              laneColor="border-rose-500" 
              isActive={activeRacerIndex === 1 && !isFinished}
              position={racer2.position}
            />
         </div>
      </div>
    </div>
  );
}
